{
	"name": "express",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx --watch --env-file=../.env.development --tsconfig tsconfig.json src/app.ts",
		"build": "tsc",
		"lint": "eslint src/**/*.ts",
		"pretest": "tsc --noEmit",
		"test": "node --experimental-test-coverage --test src/**/*.test.ts"
	},
	"dependencies": {
		"@w0s/env-value-type": "1.0.1",
		"@w0s/html-escape": "4.0.2",
		"basic-auth": "2.0.1",
		"compression": "1.8.1",
		"express": "5.2.1",
		"htpasswd-js": "1.0.2",
		"nodemailer": "8.0.4",
		"pino": "10.3.1",
		"pino-pretty": "13.1.3"
	},
	"devDependencies": {
		"@types/basic-auth": "1.1.8",
		"@types/compression": "1.8.1",
		"@types/express": "5.0.6",
		"@types/nodemailer": "8.0.0",
		"tsx": "4.21.0"
	},
	"packageManager": "pnpm@10.28.1"

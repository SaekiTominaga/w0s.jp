---
import Layout from '@layouts/Site.astro';
import MyImage from '@components/+phrasing/MyImage.astro';
import TopNavCard from '@components/TopNavCard.astro';
import TopNavCardItem from '@components/TopNavCardItem.astro';
import image_nav_blog from '@assets/index_nav_blog.png';
import image_nav_tokyu from '@assets/index_nav_tokyu.jpg';
import image_nav_kumeta from '@assets/index_nav_kumeta.jpg';
import type { StructuredData } from '../../@types/util.d.ts';

const structuredData: StructuredData = {
	type: 'website',
	title: 'w0s.jp',
	description: '富永冴樹の個人サイト',
};
---

<Layout astroFilePath={Astro.self.moduleId} structuredData={structuredData} top={true}>
	<TopNavCard>
		<TopNavCardItem title="富永日記帳" description="ウェブ技術や東急電車、久米田康治作品の話を中心としたブログ" linkHref="https://blog.w0s.jp/">
			<MyImage slot="image" image={image_nav_blog} width={360} height={180} style="--object-position: 0" />
		</TopNavCardItem>
		<TopNavCardItem title="東急電車資料室" description="目蒲デハ1形から東急(新)3000系までの車両を研究する個人サイト" linkHref="/tokyu/">
			<MyImage slot="image" image={image_nav_tokyu} width={360} height={180} style="--object-position: 80% 45%" />
		</TopNavCardItem>
		<TopNavCardItem title="久米田康治データベース" description="漫画家・久米田康治先生の作品データや周辺動向を紹介するファンサイト" linkHref="/kumeta/">
			<MyImage slot="image" image={image_nav_kumeta} width={360} height={180} />
			<!-- 2021-07-07 IMG_4978 -->
		</TopNavCardItem>
	</TopNavCard>
</Layout>

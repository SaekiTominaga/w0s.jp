---
import Layout from '@layouts/Tokyu.astro';
import Embedded from '@components/Embedded.astro';
import Grid from '@components/Grid.astro';
import GridItem from '@components/GridItem.astro';
import MyImage from '@components/+phrasing/MyImage.astro';
import Section from '@components/Section.astro';
import image_1200Ns from '@assets/tokyu/machine/ub/1200Ns.jpg';
import image_1200Nm from '@assets/tokyu/machine/ub/1200Nm.jpg';
import image_1310Ns from '@assets/tokyu/machine/ub/1310Ns.jpg';
import image_1310Nm from '@assets/tokyu/machine/ub/1310Nm.jpg';
import image_1000Ns from '@assets/tokyu/machine/ub/1000Ns.jpg';
import image_1000Nm from '@assets/tokyu/machine/ub/1000Nm.jpg';
import image_1200N1000N_sea from '@assets/tokyu/machine/ub/1200N-1000N_sea.jpg';
import image_1000N1200N_mount from '@assets/tokyu/machine/ub/1000N-1200N_mount.jpg';
import image_1310N1200N_sea from '@assets/tokyu/machine/ub/1310N-1200N_sea.jpg';
import image_1200N1310N_mount from '@assets/tokyu/machine/ub/1200N-1310N_mount.jpg';
import type { StructuredData } from '../../../../@types/util.d.ts';

const structuredData: StructuredData = {
	title: '東急1000N系（池上、多摩川線）　床下機器配置',
	heading: '1000N系　床下機器配置',
	subHeading: '池上、多摩川線',
	dateModified: '2008-02-01',
	description: '東急池上線、多摩川線で活躍する1000N系の床下機器配置を写真で紹介します。',
	image: image_1310Nm,
	breadcrumb: [
		{ path: '/tokyu/', name: '東急電車資料室' },
		{ path: '/tokyu/machine/', name: '車両機器' },
	],
	localNav: {
		label: '床下機器配置',
		items: [
			{ path: '/tokyu/machine/ub_7600', name: '7600系' },
			{ path: '/tokyu/machine/ub_7700', name: '7700系' },
			{ path: '/tokyu/machine/ub_7700n', name: '7915F' },
			{ path: '/tokyu/machine/ub_1000n', name: '1000N系池多' },
			{ path: '/tokyu/machine/ub_1000n2', name: '1000N′系' },
			{ path: '/tokyu/machine/ub_1500', name: '1000系1500番台' },
		],
	},
};
---

<Layout astroFilePath={Astro.self.moduleId} structuredData={structuredData}>
	<Section id="m1-1200">
		<Fragment slot="heading">デハ1200形（台車間）</Fragment>

		<Grid column="wide" headingType="c">
			<GridItem>
				<Section id="m1-1200-s" depth={2} headingType="c">
					<Fragment slot="heading">海側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1200Ns} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-02-09 -->
						<Fragment slot="caption">デハ1212海側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、冷房制御装置、VVVF継電器、VVVF断流器、接地開閉器とその奥にVVVFフィルタリアクトル、100V・24V整流装置、100V・24V蓄電池です。</p>
				</Section>
			</GridItem>
			<GridItem>
				<Section id="m1-1200-m" depth={2} headingType="c">
					<Fragment slot="heading">山側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1200Nm} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-02-02 -->
						<Fragment slot="caption">デハ1213山側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、VVVF主制御器（RG621-A-M型）、VVVFフィルタリアクトル、ブレーキ制御装置です。</p>
				</Section>
			</GridItem>
		</Grid>
	</Section>

	<Section id="m1c-1310">
		<Fragment slot="heading">デハ1310形（台車間）</Fragment>

		<Grid column="wide" headingType="c">
			<GridItem>
				<Section id="m1c-1310-s" depth={2} headingType="c">
					<Fragment slot="heading">海側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1310Ns} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-02-09 -->
						<Fragment slot="caption">デハ1313海側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、冷房制御装置、VVVF継電器、VVVF断流器、VVVFフィルタリアクトル、100V蓄電池、定位置停止支援装置（TASC）、接地開閉器、主幹指令装置です。</p>
				</Section>
			</GridItem>
			<GridItem>
				<Section id="m1c-1310-m" depth={2} headingType="c">
					<Fragment slot="heading">山側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1310Nm} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-02-09 -->
						<Fragment slot="caption">デハ1313山側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、VVVF主制御器（RG621-A-M型）、VVVFフィルタリアクトル、ブレーキ制御装置です。</p>
				</Section>
			</GridItem>
		</Grid>
	</Section>

	<Section id="tc-1000">
		<Fragment slot="heading">クハ1000形（台車間）</Fragment>

		<Grid column="wide" headingType="c">
			<GridItem>
				<Section id="tc-1000-sea" depth={2} headingType="c">
					<Fragment slot="heading">海側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1000Ns} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-03-01 -->
						<Fragment slot="caption">クハ1012海側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、冷房制御装置、接地開閉器、静止形インバーター（INV-020型）、SIV起動装置、空気圧縮機（HS-20型）、定位置停止支援装置（TASC）です。</p>
				</Section>
			</GridItem>
			<GridItem>
				<Section id="tc-1000-mount" depth={2} headingType="c">
					<Fragment slot="heading">山側</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1000Nm} alt="写真拡大" width={485} height={152} link={true} slot="media" />
						<!-- 撮影日: 2008-03-01 -->
						<Fragment slot="caption">クハ1013山側（3次車）</Fragment>
					</Embedded>

					<p>主な機器は下り方から順に、SIVフィルタトランス、空気圧縮機（HS-20型）、元空気だめ、ブレーキ制御装置、情報伝送装置です。</p>
				</Section>
			</GridItem>
		</Grid>
	</Section>

	<Section id="couple">
		<Fragment slot="heading">連結部</Fragment>

		<Grid column="wide" headingType="c">
			<GridItem>
				<Section id="couple1200" depth={2} headingType="c">
					<Fragment slot="heading">デハ1200形 ｰ クハ1000形間</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1200N1000N_sea} alt="写真拡大" width={485} height={243} link={true} slot="media" />
						<!-- 撮影日: 2008-02-17 -->
						<Fragment slot="caption">デハ1213 ｰ クハ1013海側</Fragment>
					</Embedded>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1000N1200N_mount} alt="写真拡大" width={485} height={243} link={true} slot="media" />
						<!-- 撮影日: 2008-02-17 -->
						<Fragment slot="caption">クハ1013 ｰ デハ1213山側</Fragment>
					</Embedded>
				</Section>
			</GridItem>
			<GridItem>
				<Section id="couple1310" depth={2} headingType="c">
					<Fragment slot="heading">デハ1310形 ｰ デハ1200形間</Fragment>

					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1310N1200N_sea} alt="写真拡大" width={485} height={243} link={true} slot="media" />
						<!-- 撮影日: 2008-02-16 -->
						<Fragment slot="caption">デハ1313 ｰ デハ1212海側</Fragment>
					</Embedded>
					<Embedded border={true} captionMeta={true}>
						<MyImage image={image_1200N1310N_mount} alt="写真拡大" width={485} height={243} link={true} slot="media" />
						<!-- 撮影日: 2008-02-16 -->
						<Fragment slot="caption">デハ1212 ｰ デハ1313山側</Fragment>
					</Embedded>
				</Section>
			</GridItem>
		</Grid>
	</Section>
</Layout>

---
interface Props {
	width?: number;
	border?: boolean;
	captionMeta?: boolean;
}

const { width, border, captionMeta } = Astro.props;
---

<figure class:list={[{ '-border': border }]} data-width={width} style={width !== undefined ? `--_width: ${width}px` : undefined}>
	<div class="embedded">
		<slot name="media" />
	</div>
	{
		Astro.slots.has('caption') && (
			<figcaption class:list={[{ '-meta': captionMeta }]}>
				<slot name="caption" />
			</figcaption>
		)
	}
</figure>

<style>
	@layer component {
		figure {
			--_border-width: 0px;

			/* stylelint-disable property-layout-mappings */
			/* stylelint-disable-next-line declaration-property-value-no-unknown */
			max-width: attr(data-width px);

			@supports not (x: attr(x px)) {
				/* stylelint-disable-next-line no-unknown-custom-properties */
				max-width: var(--_width);
			}
			/* stylelint-enable property-layout-mappings */

			&.-border {
				--_border-width: 1px;
			}
		}

		.embedded {
			contain: layout;

			& > :global(:any-link) {
				--_expand-icon-padding: 4px;

				display: inline flow-root;
				outline-offset: -1px;
				outline-width: var(--outline-width-bold);
			}

			& > :global(:any-link::before) {
				display: block flow;
				position: absolute;
				background-color: rgb(0 0 0 / 70%);
				background-image: url('/assets/image/media-expansion.svg');
				background-origin: content-box;
				background-position: center;
				background-repeat: no-repeat;
				background-size: contain;
				padding: var(--_expand-icon-padding);
				block-size: 24px;
				inline-size: 24px;
				content: '';
			}

			& > :global(:any-link:hover) {
				--_expand-icon-padding: 3px;
			}

			& :global(:is(img, video)) {
				box-sizing: revert;
				display: inline flow-root;
				block-size: auto;
				max-inline-size: 100%;
				vertical-align: top;
			} /* <audio> については block-size: auto を指定すると Chrome で非表示になる現象があるので、ブラウザのデフォルトスタイルに任せる */

			& :global(:is(img, video):not(:focus)) {
				outline: var(--_border-width) solid var(--color-black);
			}

			& :global(video) {
				outline-width: var(--outline-width-bold);
			}

			& :global(audio) {
				outline-offset: 0;
				outline-width: var(--outline-width-bold);
			}

			& :global(iframe) {
				--_margin-inline: 0px; /* 左右の空き（空きがないとタップによるスクロールに支障が起こるため） */

				display: block flow;
				margin-inline: auto;
				outline: var(--_border-width) solid var(--color-black);
				aspect-ratio: var(--aspect-ratio, auto);
				block-size: auto;
				inline-size: calc(100% - var(--_margin-inline) * 2);

				@media (width <= 60em) {
					--_margin-inline: 15px;
				}
			}
		}

		figcaption {
			inline-size: fit-content;
			line-height: var(--line-height-narrow);
			color: var(--color-gray);
			font-size: calc(100% / pow(var(--font-ratio), 1));

			.embedded + & {
				margin-block-start: 0.5em;
			}

			/* メタデータ */
			&.-meta {
				margin-inline-start: auto;
				padding-inline-start: 10%;
			}
		}
	}
</style>

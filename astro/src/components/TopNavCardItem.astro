---
interface Props {
	linkHref: string;
	title: string;
	description: string;
}

const { linkHref, title, description } = Astro.props;
---

<li class="box">
	<a href={linkHref}>
		{
			Astro.slots.has('image') && (
				<div class="image">
					<slot name="image" />
				</div>
			)
		}
		<div class="title">{title}</div>
		<p class="description">{description}</p>
	</a>
</li>

<style>
	@layer component {
		.box {
			display: block flex; /* リンクのクリッカブルエリアを上下方向に伸ばすため */
			flex-wrap: nowrap;

			& > :global(a) {
				flex-basis: 0;
				flex-grow: 1;
				outline-offset: -1px;
				outline-width: var(--outline-width-bold);
				border: 1px solid var(--border-color-light);
				border-radius: var(--border-radius-normal);
				box-shadow: 0 1px 2px var(--border-color-light);
				background-color: var(--bgcolor-light);
				overflow: hidden;
				text-decoration-line: none;
				color: var(--color-darkgray);

				&:hover {
					background-color: oklch(from var(--bgcolor-light) calc(l + var(--bgcolor-hover-l)) c h);
					color: var(--color-black);
				}
			}
		}

		.image {
			& :global(img) {
				display: block flow;
				inline-size: 100%;
				object-fit: cover;
				object-position: var(--object-position, center);

				@container (inline-size <= calc(15.3em * 2 + 15px)) {
					/* 1列表示の時のみ画像高さを狭くする */
					max-block-size: 15dvb;
				}
			}
		}

		.title {
			--_icon-inline-size: 0.5625em; /* アイコンの幅 */
			--_icon-block-size: 1em; /* アイコンの高さ */

			contain: content;
			margin: 16px;
			padding-inline-end: calc(0.75em + var(--_icon-inline-size));
			line-height: var(--line-height-narrow);
			font-size: 150%;
			font-weight: var(--font-weight-bold);

			/* 画像がない場合 */
			&:first-child {
				margin-block-start: 16px;
			}

			&::after {
				position: absolute;
				inset-block-start: calc(50% - var(--_icon-block-size) / 2);
				inset-inline-end: 0;
				border-block-start: var(--_icon-block-size) solid currentColor;
				clip-path: var(--shape-link-arrow);
				inline-size: var(--_icon-inline-size);
				content: '';
			}
		}

		.description {
			margin: 8px 16px 16px;
		}
	}
</style>

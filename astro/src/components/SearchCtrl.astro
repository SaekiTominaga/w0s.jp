---
import { getHTMLId } from '@util/crypto.ts';

const buttonTitleId = getHTMLId();
---

<div class="search">
	<span class="hidden">
		<input type="hidden" name="as_sitesearch" value="w0s.jp" />
	</span>
	<span class="query">
		<input type="search" name="q" required="" title="キーワード" />
	</span>
	<span class="submit">
		<button>
			<svg role="img" aria-labelledby={buttonTitleId}>
				<title id={buttonTitleId}>検索</title>
				<use href="/assets/image/icon/search.svg#icon"></use>
			</svg>
		</button>
	</span>
</div>

<style>
	@layer component {
		.search {
			--_border-color: var(--border-color-dark);

			display: block flex;
			flex-wrap: wrap;
			align-items: center;
			outline-offset: -1px;
			border: 1px solid var(--_border-color);
			border-radius: var(--border-radius-small);
			background-color: var(--color-white);
			color: var(--color-darkgray);

			&:focus-within {
				outline: var(--outline-width-bold) solid var(--outline-color);
			}

			&:hover {
				--_border-color: var(--outline-color);
			}
		}

		/* <input type="hidden"> */
		.hidden {
		}

		/* キーワード入力欄 */
		.query {
			flex-basis: 0;
			flex-grow: 1;

			& > :global(input) {
				all: unset;
				box-sizing: revert;
				display: block flow;
				padding: 0.25em;
				inline-size: 100%;
			}
		}

		/* 送信ボタン */
		.submit {
			& > :global(button) {
				all: unset;
				box-sizing: revert;
				display: block flow;
				margin: var(--outline-width-bold);
				padding: 0.25em;
				block-size: 2em;
				inline-size: 2em;
				color: oklch(from var(--color-blue) l calc(c - 0.15) h);
				fill: currentColor; /* SVG */
			}

			& > :global(button:focus-visible) {
				outline: var(--outline-width-bold) dotted var(--color-black);
			}

			& > :global(button:hover) {
				background-color: oklch(from var(--color-white) calc(l - var(--bgcolor-hover-l)) c h);
			}

			& > :global(button > svg) {
				block-size: 100%;
				inline-size: 100%;
			}
		}
	}
</style>

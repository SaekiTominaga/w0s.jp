---
interface Props {
	class: string;
}

const { class: className } = Astro.props;
---

<button type="button" class:list={['button', className]} {...Astro.props}><slot /></button>

<style>
	@layer component {
		.button {
			outline-offset: -1px;
			outline-width: var(--outline-width-bold);
			border: 1px solid var(--border-color-dark);
			border-radius: var(--border-radius-normal);
			background-image: linear-gradient(var(--color-white), var(--bgcolor-dark));
			padding: 0.75em;
			line-height: var(--line-height-nowrap);
			color: var(--color-black);
			font-weight: var(--font-weight-bold);

			&:focus:not(:focus-visible) {
				outline: none;
			}

			&:hover {
				box-shadow: var(--box-shadow-length) var(--box-shadow-color);
			}
		}
	}
</style>

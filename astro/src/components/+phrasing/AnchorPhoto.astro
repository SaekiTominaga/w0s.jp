---
import type { ImageMetadata } from 'astro';
import AnchorIcon from './AnchorIcon.astro';

interface Props {
	image: ImageMetadata;
	title?: string;
}

const { image, title } = Astro.props;
---

<a href={image.src} type="image/jpeg"><slot /></a><AnchorIcon fileName="image.svg" alt="写真" />{title !== undefined && <small>（リンク先写真は{title}）</small>}

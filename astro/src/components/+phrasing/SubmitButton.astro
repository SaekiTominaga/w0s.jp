---
interface Props {
	type?: 'button' | 'reset';
	formaction?: string;
	formmethod?: 'get' | 'post';
	name?: string;
	value?: string;
	id?: string;
	buttonStyle?: 'compact' | 'cancel';
	class?: string;
}

const { type, formaction, formmethod, name, value, id, buttonStyle, class: className } = Astro.props;
---

<button type={type} formaction={formaction} formmethod={formmethod} name={name} value={value} id={id} class:list={['submit', buttonStyle !== undefined ? `-${buttonStyle}` : undefined, className]} {...Astro.props}><slot /></button>

<style>
	@layer component {
		.submit {
			--_border-color: var(--form-control-theme-color);
			--_bg-color: var(--form-control-theme-color);
			--_bg-color-hover: oklch(from var(--form-control-theme-color) calc(l + var(--bgcolor-hover-l)) c h); /* 太字の 15pt なのでコントラスト比の基準は 3:1 以上 */
			--_padding-block: calc(var(--form-control-padding-block) - (1lh * (pow(var(--font-ratio), var(--_font-size-exp)) - 1)) / 2);
			--_padding-inline: 1em;
			--_color: var(--color-white);
			--_font-size-exp: 2;
			--_ripple-color: var(--color-white);
			--_ripple-opacity: 0.25;
			--_ripple-transition-duration: 0.5s;

			display: inline flow-root;
			outline-offset: 1px;
			outline-width: var(--outline-width-bold);
			contain: layout; /* ripple effect */
			border: 1px solid var(--_border-color);
			border-radius: var(--border-radius-normal);
			background-color: var(--_bg-color);
			padding: var(--_padding-block) var(--_padding-inline);
			overflow: hidden; /* ripple effect */
			vertical-align: middle;
			text-wrap-mode: nowrap;
			color: var(--_color);
			font-family: system-ui, sans-serif; /* Chrome で下側の空きが出てしまう対策 */
			font-size: calc(100% * pow(var(--font-ratio), var(--_font-size-exp)));
			font-weight: var(--font-weight-bold);

			&:enabled {
				&:hover {
					--_bg-color: var(--_bg-color-hover);
				}

				/* ripple effect */
				&::before {
					position: absolute;
					inset: 0;
					transform: scale(4);
					transition-duration: var(--_ripple-transition-duration);
					opacity: 0;
					background-image: radial-gradient(circle, var(--_ripple-color) 25%, transparent 0);
					block-size: 100%;
					inline-size: 100%;
					content: '';
				}

				/* ripple effect */
				&:active::before {
					transform: scale(0);
					transition-duration: initial;
					opacity: var(--_ripple-opacity);
				}
			}

			/* コンパクトなボタン */
			&.-compact {
				--_padding-block: 0.125em;
				--_padding-inline: 0.375em;
				--_font-size-exp: 0;
			}

			/* キャンセルボタン */
			&.-cancel {
				--_padding-block: 0.125em;
				--_color: var(--color-darkgray);
				--_bg-color: var(--color-white);
				--_bg-color-hover: oklch(from var(--color-white) calc(l - var(--bgcolor-hover-l)) c h);
				--_border-color: var(--_color);
				--_font-size-exp: 0;
				--_ripple-color: var(--color-black);
			}
		}
	}
</style>

---
import type GithubSlugger from 'github-slugger';
import SelfLink from './+phrasing/SelfLink.astro';

type Depth = 1 | 2 | 3;
type HeadingType = 'a' | 'b' | 'c';

interface Props {
	id: string | GithubSlugger;
	depth?: Depth;
	box?: boolean;
	autofocus?: boolean;
	class?: string;
}

const { id, depth = 1, box = false, autofocus = false, class: className } = Astro.props;

const headingHtml = await Astro.slots.render('heading');

const getHeadingType = (): HeadingType =>
	new Map<Depth, HeadingType>([
		[1, 'a'],
		[2, 'b'],
		[3, 'c'],
	]).get(depth) ?? 'a';

const getSectionId = (): string => {
	if (typeof id === 'string') {
		return id;
	}

	const headingText = headingHtml.replaceAll(/<.+?>/gv, '');

	return id.slug(headingText);
};

const sectionId = getSectionId();
---

<section autofocus={autofocus} tabindex={autofocus ? -1 : undefined} class:list={['section', `-${getHeadingType()}`, { '-box': box }, className]} id={sectionId}>
	<div class="hdg">
		{depth === 1 && <h2 set:html={headingHtml} />}
		{depth === 2 && <h3 set:html={headingHtml} />}
		{depth === 3 && <h4 set:html={headingHtml} />}
		<p class="self-link"><SelfLink id={sectionId} /></p>
	</div>

	<slot />
</section>

<style>
	@layer component {
		@keyframes section-target {
			0% {
				background-color: var(--bgcolor-lightred);
			}

			50% {
				background-color: var(--bgcolor-lightred);
			}

			100% {
				background-color: transparent;
			}
		}

		.section {
			--_margin-block: 1rem;

			&:target {
				animation-name: section-target;
				animation-duration: 1s;
			}

			&:not(:first-child) {
				margin-block-start: var(--_margin-block);
			}

			.hdg + & /* Astro ビルドで :not() が使えないため上書き */ {
				margin-block-start: var(--stack-margin-base);
			}

			&:not(:last-child) {
				margin-block-end: var(--_margin-block);
			}

			&.-a {
				--_margin-block: 4.5rem;
			}

			&.-b {
				--_margin-block: 3.75rem;
			}

			&.-c {
				--_margin-block: 3rem;
			}

			&.-box {
				border: 1px solid var(--border-color-dark);
				border-radius: var(--border-radius-normal);
				background-color: var(--color-white);
				padding: 1em;
			}

			& > :global(* + *) {
				margin-block-start: var(--stack-margin-base);
			}
		}

		.hdg {
			display: block flex;
			flex-wrap: nowrap;
			gap: 0.5em;
			line-height: var(--line-height-narrow);

			.section.-a > & {
				margin-block-end: 2rem;
				border-block-end: 1px solid var(--border-color-dark);
				padding-block-end: 0.375em;
				font-size: calc(100% * pow(var(--font-ratio), 6));
			}

			.section.-a > &::before {
				border: 0.125em solid var(--color-gray);
				border-radius: var(--border-radius-full);
				background-color: var(--color-gray); /* for Chrome */
				content: '';

				@media not print {
					/* Firefox の印刷プレビューで2ページ目以降の場合に縦線が上方にずれてしまうバグの対策 */
					transform: scaleY(75%);
				}
			}

			.section.-b > & {
				font-size: calc(100% * pow(var(--font-ratio), 3));
			}

			.section.-b > &::before {
				transform: scaleY(75%);
				border: 0.125em solid var(--color-lightgray);
				border-radius: var(--border-radius-full);
				background-color: var(--color-lightgray); /* for Chrome */
				content: '';
			}

			.section.-c > & {
				font-size: calc(100% * pow(var(--font-ratio), 2));
			}

			& :global(small) {
				font-weight: var(--font-weight-normal);
			}
		}

		.self-link {
			display: block flex;
			flex-wrap: nowrap;
			align-items: center;
			font-size: calc(100% / pow(var(--font-ratio), 3));
		}
	}
</style>

{
	"name": "astro",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev && vitest --coverage --watch",
		"prebuild": "astro check && tsc --noEmit && stylelint src/components/**/*.astro && pnpm -F frontend build",
		"build": "astro build && pnpm run /^build:.*/",
		"build:feed": "node build/feed.ts -t ../template/xml -o dist/client",
		"build:sitemap": "node build/sitemap.ts -t ../template/xml/sitemap.ejs -o dist/client --ignore 4** --ignore 5** --ignore admin",
		"postbuild": "prettier --config ../.prettierrc.mjs -w dist/client/**/*.html dist/client/assets/astro/*.css && brotli-cli compress -g dist/client/**/*.{html,atom} -g dist/client/assets/astro/*.css -m text",
		"lint": "pnpm run /^lint:.*/",
		"lint:html": "markuplint src/pages/**/*.astro",
		"lint:css": "stylelint -f verbose src/**/*.astro",
		"lint:js": "astro sync && eslint @types build src",
		"lint-html-dist": "markuplint dist/client/**/*.html",
		"pretest": "astro sync && tsc --noEmit",
		"test": "pnpm run /^test:.*/",
		"test:node": "node --experimental-test-coverage --test build/**/*.test.ts src/+util/*.test.ts src/middleware/*.test.ts",
		"test:vitest": "vitest run"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.0.6",
		"@w0s/env-value-type": "2.0.0",
		"@w0s/html-escape": "5.0.0",
		"@w0s/isbn-verify": "4.0.0",
		"@w0s/paapi-item-image-url-parser": "4.0.0",
		"@w0s/sqlite-utility": "3.0.0",
		"@w0s/urlsearchparams-custom-separator": "4.0.0",
		"@w0s/wareki": "2.0.0",
		"astro": "6.2.2",
		"better-sqlite3": "12.9.0",
		"commonmark": "0.31.2",
		"dayjs": "1.11.20",
		"diff": "9.0.0",
		"dompurify": "3.4.2",
		"ejs": "5.0.2",
		"github-slugger": "2.0.0",
		"highlight.js": "11.11.1",
		"js-yaml": "4.1.1",
		"jsdom": "29.1.1",
		"kysely": "0.28.16",
		"node-html-parser": "7.1.0",
		"nodemailer": "8.0.7",
		"sharp": "0.34.5",
		"slash": "5.1.0",
		"winston": "3.19.0",
		"winston-transport": "4.9.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"@types/commonmark": "0.27.10",
		"@types/ejs": "3.1.5",
		"@types/js-yaml": "4.0.9",
		"@types/jsdom": "28.0.1",
		"@types/nodemailer": "8.0.0",
		"@vitest/coverage-v8": "4.1.5",
		"astro-eslint-parser": "1.4.0",
		"eslint-plugin-astro": "1.7.0",
		"postcss-nesting": "14.0.0",
		"stylelint-config-astro": "2.0.0",
		"vitest": "4.1.5"
	},
	"packageManager": "pnpm@10.28.1"
}
